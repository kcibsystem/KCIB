// ===================== ROUTER =====================
function doGet(e) {
  const p = e.parameter || {};
  if (p.action === "chat") { return chatWithGemini(p.message); }
  if (p.action === "process_email") { return handleEmailAction(p.type, p.bookingId); }
  try {
    switch (p.func) {
      case "init":          return jsonOut(getInitData());
      case "getMyBookings": return jsonOut(getMyBookings(p.email));
      case "getAllBookings": return jsonOut(getAllBookings());
      default:              return jsonOut({ error: "Invalid function" });
    }
  } catch (err) { return jsonOut({ error: err.message }); }
}

function doPost(e) {
  try {
    const data = JSON.parse(e.postData.contents || "{}");
    switch (data.action) {
      case "submitBooking": return jsonOut(submitBooking(data));
      case "cancelBooking": return jsonOut(cancelBooking(data));
      case "chat":          return chatWithGemini(data.message);
      default:              return jsonOut({ error: "Invalid action" });
    }
  } catch (err) { return jsonOut({ error: err.message }); }
}

// ===================== GEMINI AI FUNCTION =====================
function chatWithGemini(userMessage) {
  const API_KEY = "AIzaSyCUeQYZMC3uiq2h6hZyJ2QVjtI-NLXMp4A"; 
  const url = "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=" + API_KEY;
  
  const payload = {
    contents: [{
      parts: [{ text: "คุณคือผู้ช่วย AI ของระบบ KCIB ภาควิชาวิศวกรรมเคมี สจล. ตอบคำถามอย่างสุภาพ\n\nUser: " + userMessage }]
    }]
  };
  
  const options = {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };
  
  try {
    const response = UrlFetchApp.fetch(url, options);
    const data = JSON.parse(response.getContentText());
    if (data.candidates && data.candidates[0].content.parts[0].text) {
      return jsonOut({ status: 'success', reply: data.candidates[0].content.parts[0].text });
    } else {
      throw new Error("Gemini Error: " + response.getContentText());
    }
  } catch (err) {
    return jsonOut({ status: 'error', message: err.toString() });
  }
}
